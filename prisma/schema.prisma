generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  createdAt DateTime        @default(now())
  users     WorkspaceUser[]
  clients   Client[]
  sessions  AnalysisSession[]
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime        @default(now())
  accounts      Account[]
  workspaces    WorkspaceUser[]
  sessions      Session[]
}

model WorkspaceUser {
  id          String    @id @default(cuid())
  role        String    @default("ANALYST") // SUPER_ADMIN | ADMIN | ANALYST
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId String
  user        User      @relation(fields: [userId], references: [id])
  userId      String

  @@unique([workspaceId, userId])
}

model Client {
  id          String            @id @default(cuid())
  name        String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id])
  workspaceId String
  sessions    AnalysisSession[]
  createdAt   DateTime          @default(now())
}

model AnalysisSession {
  id             String           @id @default(cuid())
  workspace      Workspace        @relation(fields: [workspaceId], references: [id])
  workspaceId    String
  client         Client?          @relation(fields: [clientId], references: [id])
  clientId       String?
  platform       String           // META | GOOGLE | BOTH
  dateRangeStart DateTime?
  dateRangeEnd   DateTime?
  language       String           @default("tr") // tr | en
  status         String           @default("PENDING") // PENDING | PROCESSING | DONE | ERROR
  campaigns      CampaignResult[]
  overallReport  Json?
  createdAt      DateTime         @default(now())
}

model CampaignResult {
  id         String          @id @default(cuid())
  session    AnalysisSession @relation(fields: [sessionId], references: [id])
  sessionId  String
  platform   String          // META | GOOGLE
  name       String
  metrics    Json
  aiAnalysis String?         @db.Text
  actions    Json?
  score      Int?            // 0-100 performans skoru
  createdAt  DateTime        @default(now())
}

// NextAuth zorunlu modeller
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
